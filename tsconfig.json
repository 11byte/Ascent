// tsconfig.json (Use this as the definitive file)
{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    // --- Path Resolution Configuration ---
    "baseUrl": "./src", // This tells TypeScript to start looking inside the 'src' folder
    "paths": {
      "@components/*": ["./components/*"],
      "@styles/*": ["./styles/*"],
      "@utils/*": ["./utils/*"],
      "@hooks/*": ["./hooks/*"],
      "@services/*": ["./services/*"],
      "@context/*": ["./context/*"],
      "@/components/*": ["./components/*"],
      // The most versatile alias: Maps @/ to the src/ folder.
      // E.g., @/app/page.tsx or @/components/ui/button.tsx
      "@/*": ["./*"],
      // We must define app explicitly since Next.js uses it heavily
      "@/app/*": ["./app/*"]
    }
    // ------------------------------------
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "backend/src/seeds/seedClub.js"
  ],
  "exclude": ["node_modules", "backend/**/*.ts", "backend/**/*.tsx"]
}
