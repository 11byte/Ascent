# Copy this file to .env in project root before running docker compose.
# Command (PowerShell): Copy-Item .example.env .env




# --------------------------------------------------
# Docker image selection (used by docker-compose.images.yml)
# --------------------------------------------------
# Your Docker Hub username/organization that owns the private repo.
# Example: pareshgupta
DOCKER_NAMESPACE=pareshgupta

# Image version tag. Compose will pull:
# - ${DOCKER_NAMESPACE}/ascent:backend-${IMAGE_TAG}
# - ${DOCKER_NAMESPACE}/ascent:frontend-${IMAGE_TAG}
# Example: v1, v2, v3
IMAGE_TAG=v1

# --------------------------------------------------
# Backend required secret
# --------------------------------------------------
# REQUIRED. Backend will fail to start if JWT_SECRET is empty.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
JWT_SECRET=

# --------------------------------------------------
# Optional API keys (features may fail if empty)
# --------------------------------------------------
# Gemini API key
# How to get:
# 1) Go to Google AI Studio or Google Cloud Console.
# 2) Enable Gemini API / Generative Language API.
# 3) Create API key and paste here.
GEMINI_API_KEY=

# Google API key for book + YouTube usage
# How to get:
# 1) Go to Google Cloud Console.
# 2) Enable APIs used by project (YouTube Data API v3 and Books API).
# 3) Create API key and paste here.
GOOGLE_API_KEY=
