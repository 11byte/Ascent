// =====================================================
//  Ascent Platform Prisma Schema
// =====================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------- Enums ----------------
enum BlogDomain {
  AI
  ML
  Cyber
  DevOps
  Blockchain
  Cloud
  General
}

// ---------------- Models ----------------
model User {
  id           Int               @id @default(autoincrement())
  userId       String            @unique                      // ✅ External user identifier (used across Kafka & frontend)
  email        String            @unique
  password     String
  name         String
  phase        String            @default("1")
  githubId     String?           @unique
  githubToken  String?

  // Relationships
  blogs        Blog[]            @relation("UserBlogs")
  interactions BlogInteraction[] @relation("UserInteractions")
  skills       Skill[]
  achievements Achievement[]
  trackerSessions  TrackerSession[]

  //roadmap
  roadmaps        Roadmap[]         @relation("UserRoadmaps")
  roadmap_credits Int       @default(0) // New field

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Blog {
  id        Int        @id @default(autoincrement())
  title     String
  content   String
  topic     BlogDomain @default(General)

  author    User?       @relation("UserBlogs", fields: [authorId], references: [id])
  authorId  Int?

  createdAt DateTime    @default(now())
}

model BlogInteraction {
  id          Int      @id @default(autoincrement())
  blogTitle   String
  interested  Boolean
  domain      String
  // ✅ Updated relationship: link by `userId` (string field) instead of numeric `id`
  user        User?    @relation("UserInteractions", fields: [userRefId], references: [userId])
  userRefId   String?                                   // renamed from userId → userRefId for clarity
  createdAt   DateTime @default(now())
}

model Skill {
  id        Int      @id @default(autoincrement())

  // timeline fields
  phase     String                      // 1,2,3,4 (engineering year)
  category  String                      // Technical Skills, Academics etc
  skillName String                      // MERN App, Hackathon Winner etc

  // optional metadata
  level     String?                     // beginner, intermediate, advanced
  proofUrl  String?                     // github repo, certificate link
  source    String?                     // manual, github, leetcode, hackathon

  // relation
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?

  createdAt DateTime @default(now())
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  user        User?    @relation(fields: [userId], references: [id])
  userId      Int?

  createdAt   DateTime @default(now())
}

// ---------------- Roadmap ----------------
model Roadmap {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text // ✅ Use @db.Text for large JSON roadmap strings
  searchCount Int      @default(0)

  // ✅ ADD THE RELATION NAME "UserRoadmaps" TO MATCH THE USER MODEL
  user        User     @relation("UserRoadmaps", fields: [userId], references: [id])
  userId      Int

  createdAt   DateTime @default(now())
}

// ---------------- Tracker -----------------
model TrackerSession {
  id             String   @id @default(uuid())
  userId         String
  assignedDomain String
  metrics        Json
  createdAt      DateTime @default(now())

  user            User    @relation(fields: [userId], references: [userId])

}

model Club {
  id          Int      @id @default(autoincrement())
  name        String
  tagline     String
  description String
  president   String

  events      Event[]
  challenges  Challenge[]
  members     ClubMember[]
  macrothons Macrothon[]

  createdAt   DateTime @default(now())
}

model Event {
  id        Int      @id @default(autoincrement())
  title     String
  date      String
  time      String
  venue     String
  speaker   String
  status    String

  club      Club?    @relation(fields: [clubId], references: [id])
  clubId    Int?
}

model Challenge {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  points      Int
  clubName    String?

  club        Club?    @relation(fields: [clubId], references: [id])
  clubId      Int?
}

model ClubMember {
  id      Int    @id @default(autoincrement())
  name    String
  role    String
  tier    String

  club    Club?  @relation(fields: [clubId], references: [id])
  clubId  Int?
}

model Macrothon {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  prize       String
  startDate   String?
  deadline    String
  domain      String?

  clubId      Int?
  club        Club?    @relation(fields: [clubId], references: [id])

  createdAt   DateTime @default(now())
}